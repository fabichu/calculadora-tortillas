---
---

<section class="min-h-screen bg-[#FEF3E2] flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-[600px] flex flex-col gap-8">

    <!-- Header -->
    <header class="flex flex-col gap-3">
      <div class="w-14 h-14 rounded-full bg-[#C4461A] flex items-center justify-center text-2xl select-none">
        🌮
      </div>
      <h1 class="text-[32px] font-bold text-[#2D2926] leading-tight">
        Calculadora de Tortillas
      </h1>
      <p class="text-[15px] text-[#5E5954] leading-relaxed">
        La receta tradicional mexicana. Del comal a tu mesa.
      </p>
    </header>

    <!-- Formulario -->
    <div class="bg-[#FDE8C4] rounded-2xl p-8 flex flex-col gap-6">
      <div class="flex flex-col gap-2">
        <label for="num-tortillas" class="text-sm font-semibold text-[#2D2926]">
          Número de tortillas
        </label>
        <div class="bg-[#FEF3E2] rounded-xl px-4 flex items-center">
          <input
            id="num-tortillas"
            type="number"
            min="1"
            value="12"
            class="bg-transparent text-base text-[#2D2926] w-full py-3.5 outline-none"
          />
          <span class="text-sm text-[#8C8782] shrink-0">tortillas</span>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label for="peso-tortilla" class="text-sm font-semibold text-[#2D2926]">
          Peso por tortilla
        </label>
        <div class="bg-[#FEF3E2] rounded-xl px-4 flex items-center">
          <input
            id="peso-tortilla"
            type="number"
            min="1"
            value="30"
            class="bg-transparent text-base text-[#2D2926] w-full py-3.5 outline-none"
          />
          <span class="text-sm text-[#8C8782] shrink-0">gramos</span>
        </div>
      </div>

      <button
        id="btn-calcular"
        class="w-full bg-[#C4461A] text-[#FEF3E2] font-bold text-base rounded-full py-4 cursor-pointer hover:bg-[#A83A15] active:scale-[0.98] transition-all"
      >
        Calcular
      </button>

      <p class="text-xs text-[#8C8782] text-center">
        Receta del norte de México · 1 parte harina · 1.5 partes agua
      </p>
    </div>

    <!-- Resultados -->
    <div class="grid grid-cols-2 gap-4">
      <div class="bg-[#E8900A] rounded-2xl p-7 flex flex-col gap-2">
        <div class="flex items-center justify-between">
          <span class="text-sm font-semibold text-white">Harina</span>
          <div class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 22 16 8"/>
              <path d="M3.47 12.53 5 11l1.53 1.53a3.5 3.5 0 0 1 0 4.94L5 19l-1.53-1.53a3.5 3.5 0 0 1 0-4.94z"/>
              <path d="M7.47 8.53 9 7l1.53 1.53a3.5 3.5 0 0 1 0 4.94L9 15l-1.53-1.53a3.5 3.5 0 0 1 0-4.94z"/>
              <path d="M11.47 4.53 13 3l1.53 1.53a3.5 3.5 0 0 1 0 4.94L13 11l-1.53-1.53a3.5 3.5 0 0 1 0-4.94z"/>
            </svg>
          </div>
        </div>
        <span id="resultado-harina" class="text-5xl font-bold text-white">144</span>
        <span class="text-sm text-white/70">gramos</span>
      </div>

      <div class="bg-[#0C7A8C] rounded-2xl p-7 flex flex-col gap-2">
        <div class="flex items-center justify-between">
          <span class="text-sm font-semibold text-white">Agua</span>
          <div class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/>
              <path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/>
            </svg>
          </div>
        </div>
        <span id="resultado-agua" class="text-5xl font-bold text-white">216</span>
        <span class="text-sm text-white/70">mililitros</span>
      </div>
    </div>

  </div>
</section>

<script>
  const inputTortillas = document.getElementById("num-tortillas") as HTMLInputElement;
  const inputPeso = document.getElementById("peso-tortilla") as HTMLInputElement;
  const btnCalcular = document.getElementById("btn-calcular");
  const resultadoHarina = document.getElementById("resultado-harina");
  const resultadoAgua = document.getElementById("resultado-agua");

  function calcular() {
    const tortillas = parseFloat(inputTortillas.value) || 0;
    const peso = parseFloat(inputPeso.value) || 0;
    const total = tortillas * peso;
    // ratio 1:1.5 → total partes = 2.5
    const harina = Math.round(total / 2.5);
    const agua = Math.round(harina * 1.5);
    resultadoHarina!.textContent = harina.toString();
    resultadoAgua!.textContent = agua.toString();
  }

  btnCalcular?.addEventListener("click", calcular);
  inputTortillas?.addEventListener("input", calcular);
  inputPeso?.addEventListener("input", calcular);

  calcular();
</script>
